exec_prefix=${prefix}
libdir=${exec_prefix}/lib/linux
includedir=${prefix}/include

Name: OpenSSL-libssl
Description: Secure Sockets Layer and cryptography libraries
Version: 1.1.1w
Requires.private: libcrypto
Libs: -L${libdir} -lssl
Cflags: -I${includedir}
